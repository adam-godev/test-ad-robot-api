FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Host ports exposed by Docker Compose.
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# PostgreSQL container defaults.
POSTGRES_DB=keitaro_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend database URL inside the Docker Compose network.
# If POSTGRES_DB/USER/PASSWORD are changed, update this URL too.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/keitaro_test

# Keitaro Admin API base URL, without /admin_api/v1.
KEITARO_BASE_URL=https://demo.keitaro.io

# Keitaro Admin API key. Used only by the backend when calling Keitaro.
KEITARO_API_KEY=replace-me

# Tracking domain URL used to build campaign links in the UI.
KEITARO_CAMPAIGN_DOMAIN_URL=https://tracker.example

# Default Keitaro entity IDs used for newly created campaigns.
KEITARO_DOMAIN_ID=1
KEITARO_GROUP_ID=1
KEITARO_TRAFFIC_SOURCE_ID=1
